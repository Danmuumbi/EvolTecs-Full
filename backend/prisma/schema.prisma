generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  company       String?
  emailVerified Boolean  @default(false)
  role          String   @default("VISITOR") // VISITOR, CUSTOMER, ADMIN
  
  // Relations
  domains       Domain[]
  hosting       Hosting[]
  emails        Email[]
  orders        Order[]
  tickets       SupportTicket[]
  payments      Payment[]
  invoices      Invoice[]
  ticketResponses TicketResponse[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([email])
  @@index([role])
}

model Domain {
  id            String   @id @default(cuid())
  domainName    String   @unique
  registrationDate DateTime
  expiryDate    DateTime
  autoRenew     Boolean  @default(false)
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED, EXPIRED
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([domainName])
}

model Hosting {
  id            String   @id @default(cuid())
  planName      String
  diskSpace     Int
  bandwidth     Int
  domains       Int
  emailAccounts Int
  price         Float
  billingCycle  String
  startDate     DateTime
  expiryDate    DateTime
  autoRenew     Boolean  @default(false)
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED, EXPIRED
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails        Email[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
}

model Email {
  id            String   @id @default(cuid())
  emailAddress  String   @unique
  password      String
  quota         Int
  usedSpace     Int      @default(0)
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, CANCELLED, EXPIRED
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hostingId     String?
  hosting       Hosting? @relation(fields: [hostingId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([emailAddress])
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  totalAmount   Float
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED, FAILED
  paymentStatus String   @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  payments      Payment[]
  invoices      Invoice[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([orderNumber])
}

model OrderItem {
  id            String   @id @default(cuid())
  serviceType   String
  serviceId     String?
  name          String
  description   String?
  quantity      Int      @default(1)
  unitPrice     Float
  totalPrice    Float
  
  // Relations
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([orderId])
}

model Payment {
  id            String   @id @default(cuid())
  paymentMethod String
  transactionId String?  @unique
  amount        Float
  status        String   @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  mpesaCode     String?  @unique
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([transactionId])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  amount        Float
  dueDate       DateTime
  paidAt        DateTime?
  status        String   @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([invoiceNumber])
}

model SupportTicket {
  id            String   @id @default(cuid())
  subject       String
  message       String
  status        String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  category      String
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     TicketResponse[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

model TicketResponse {
  id            String   @id @default(cuid())
  message       String
  isAdmin       Boolean  @default(false)
  adminName     String?
  
  // Relations
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([ticketId])
}